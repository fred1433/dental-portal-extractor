# API Configuration
API_KEY=your_secure_api_key_here
PORT=3000
NODE_ENV=development

# Portal Credentials (for local development only)
# Never commit actual credentials to version control

# DNOA Portal
DNOA_USERNAME=your_dnoa_username
DNOA_PASSWORD=your_dnoa_password

# DentaQuest Portal
DENTAQUEST_USERNAME=your_dentaquest_username
DENTAQUEST_PASSWORD=your_dentaquest_password

# MetLife Portal
METLIFE_USERNAME=your_metlife_username
METLIFE_PASSWORD=your_metlife_password

# Cigna Portal
CIGNA_USERNAME=your_cigna_username
CIGNA_PASSWORD=your_cigna_password

# DOT (Dental Office Toolkit) Portal
# For assisted login (local development only)
DOT_USERNAME=your_dot_username
DOT_PASSWORD=your_dot_password_local_only

# DOT Session for Production (Render)
# Generate this by running: cd dot-extractor && npm run login:assist
# Copy the base64 string from the output
DOT_SESSION_B64=paste_base64_session_here_for_production

# Other Portal Sessions (if using environment-based sessions)
DNOA_SESSION_B64=
DENTAQUEST_SESSION_B64=
METLIFE_SESSION_B64=
CIGNA_SESSION_B64=